{
  "name": "aditya-dashboard",
  "productName": "ADITYA",
  "author": "ADITYA OS",
  "description": "ADITYA Cognitive Core",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:dev": "electron . --dev",
    "electron:pack": "vite build && electron-builder --dir",
    "electron:dist": "vite build && electron-builder"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "rcedit": "^5.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.aditya.dashboard",
    "publish": null,
    "afterPack": "afterPack.cjs",
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "loading.html"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/AdityaCore.exe",
        "to": "AdityaCore.exe"
      },
      {
        "from": "dist",
        "to": "client/dist"
      },
      {
        "from": "../.env",
        "to": ".env"
      },
      {
        "from": "../backend/data",
        "to": "data"
      },
      {
        "from": "../backend/skills",
        "to": "skills"
      },
      {
        "from": "../backend/sounds",
        "to": "sounds"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        }
      ],
      "icon": "public/tray_icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerIcon": "public/tray_icon.ico",
      "uninstallerIcon": "public/tray_icon.ico",
      "installerSidebar": "build/sidebar.bmp",
      "uninstallerSidebar": "build/unsidebar.bmp",
      "installerHeader": "build/header.bmp",
      "uninstallDisplayName": "ADITYA"
    }
  }
}
